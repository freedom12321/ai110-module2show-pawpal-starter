classDiagram
    direction TB

    class Priority {
        <<enumeration>>
        HIGH = 1
        MEDIUM = 2
        LOW = 3
    }

    class CareTask {
        +String name
        +int duration
        +Priority priority
        +String category
        +bool required
        +String frequency
        +String preferred_time
        +String start_time
        +bool completed
        +String last_completed_date
        +String next_due_date
        +update_task(kwargs)
        +mark_complete(date)
        +reset()
        +is_due_today(date) bool
        +get_next_occurrence(completed_date) CareTask
        +get_task_summary() String
    }

    class Pet {
        +String name
        +String species
        +String breed
        +int age
        +String energy_level
        +List~CareTask~ tasks
        +add_task(task CareTask)
        +remove_task(task_name String)
        +get_tasks(category, required_only) List
        +update_pet_info(kwargs)
        +get_pet_summary() String
    }

    class Owner {
        +String name
        +int available_time
        +List~String~ preferences
        +List~Pet~ pets
        +add_pet(pet Pet)
        +get_all_tasks(pet_name, exclude_completed) List
        +update_profile(name, available_time, preferences)
        +get_availability() int
    }

    class Scheduler {
        +Owner owner
        +List~CareTask~ scheduled_tasks
        +List~CareTask~ skipped_tasks
        +sort_tasks(tasks) List
        +sort_by_time(tasks) List
        +filter_tasks(tasks, status, pet_name) List
        +detect_conflicts(tasks) List~String~
        +reschedule_completed_tasks(pet, completed_date) List
        +generate_plan(date) DailyPlan
        +explain_plan() String
    }

    class DailyPlan {
        +String date
        +Owner owner
        +List~CareTask~ scheduled_tasks
        +List~CareTask~ skipped_tasks
        +int total_time_used
        +List~String~ warnings
        +display_plan()
        +show_skipped_tasks()
        +get_summary() String
    }

    %% ── Relationships ──────────────────────────────────────────────────
    Owner "1" --> "1..*" Pet       : owns
    Pet   "1" --> "0..*" CareTask  : has
    CareTask   -->        Priority  : uses

    Scheduler  -->        Owner     : reads tasks and availability from
    Scheduler  -->        DailyPlan : generates

    DailyPlan  -->        Owner     : references
    DailyPlan "1" --> "0..*" CareTask : contains
